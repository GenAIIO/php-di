{
    "name": "genai/di",
    "description": "Popular DI attributes (#[Service], #[Repository], #[Configuration], #[Bean], #[Value]) and their processor, targeting GenAI\\Container. Build-time (PHP 8).",
    "type": "library",
    "license": "Apache-2.0",
    "repositories": [
        { "type": "path", "url": "../php-attribute" },
        { "type": "path", "url": "../php-container" }
    ],
    "require": {
        "php": ">=8.0",
        "genai/attribute": "*",
        "genai/container": "*"
    },
    "extra": {
        "genai": {
            "processors": ["GenAI\\Di\\Processor\\ComponentProcessor"]
        }
    },
    "autoload": {
        "psr-4": {
            "GenAI\\Di\\": "src/"
        }
    }
}
